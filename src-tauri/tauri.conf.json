{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "AirPDF",
  "version": "0.1.0",
  "identifier": "com.alfredopachas.airpdf",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "AirPDF",
        "width": 1280,
        "height": 800,
        "minWidth": 800,
        "minHeight": 600,
        "dragDropEnabled": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["msi", "nsis"],
    "publisher": "Alfredo Pachas",
    "category": "Productivity",
    "shortDescription": "Editor de PDFs standalone con IA opcional",
    "longDescription": "AirPDF reemplaza Adobe Acrobat Pro y Xodo. Standalone, instalable en Windows, con integracion opcional con Claude Code para funciones de IA.",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": ["pdfium/bin/pdfium.dll"],
    "fileAssociations": [
      {
        "ext": ["pdf"],
        "name": "PDF Document",
        "description": "Portable Document Format"
      }
    ],
    "windows": {
      "wix": {
        "language": ["es-ES", "en-US"]
      }
    }
  }
}
