{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "AirPDF",
  "version": "0.3.1",
  "identifier": "com.alfredopachas.airpdf",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "AirPDF",
        "width": 1280,
        "height": 800,
        "minWidth": 800,
        "minHeight": 600,
        "dragDropEnabled": true
      }
    ],
    "security": {
      "csp": null,
      "assetProtocol": {
        "enable": true,
        "scope": ["**"]
      }
    }
  },
  "plugins": {
    "updater": {
      "active": true,
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDgzNTk4Q0M2OEI0QUNCNTQKUldSVXkwcUx4b3haZzVzcVdOVmpFVjNGL09GWENSMzVqdExIb2Zpa01SeTVMNFd5MFJ6S1ovQm8K",
      "endpoints": [
        "https://github.com/ALF0305/air-pdf/releases/latest/download/latest.json"
      ]
    }
  },
  "bundle": {
    "active": true,
    "createUpdaterArtifacts": true,
    "targets": ["msi", "nsis"],
    "publisher": "Alfredo Pachas",
    "category": "Productivity",
    "shortDescription": "Editor de PDFs standalone con IA opcional",
    "longDescription": "AirPDF reemplaza Adobe Acrobat Pro y Xodo. Standalone, instalable en Windows, con integracion opcional con Claude Code para funciones de IA.",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": ["pdfium/bin/pdfium.dll"],
    "fileAssociations": [
      {
        "ext": ["pdf"],
        "name": "AirPDF.Document",
        "description": "PDF Document",
        "role": "Editor",
        "mimeType": "application/pdf"
      }
    ],
    "windows": {
      "wix": {
        "language": ["es-ES", "en-US"]
      }
    }
  }
}
